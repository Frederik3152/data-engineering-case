{
  "datasets": [
    {
      "name": "fedd8847",
      "displayName": "cost_breakdown",
      "queryLines": [
        "WITH run_outcomes AS (\r\n",
        "  SELECT\r\n",
        "    run_id,\r\n",
        "    MAX_BY(result_state, period_end_time) AS final_state\r\n",
        "  FROM\r\n",
        "    system.lakeflow.job_run_timeline\r\n",
        "  WHERE\r\n",
        "    result_state IS NOT NULL\r\n",
        "  GROUP BY\r\n",
        "    run_id\r\n",
        "),\r\n",
        "job_usage AS (\r\n",
        "  SELECT\r\n",
        "    u.sku_name,\r\n",
        "    u.usage_date,\r\n",
        "    REPLACE(u.usage_metadata.job_name, '[dev frederik_toernstroem] ', '') AS job_name,\r\n",
        "    CASE WHEN u.usage_metadata.job_name LIKE '[dev%' THEN 'Dev'\r\n",
        "    ELSE 'Prod' END AS environment,\r\n",
        "    u.usage_metadata.job_run_id AS job_run_id,\r\n",
        "    lp.pricing.default AS price,\r\n",
        "    lp.currency_code AS currency,\r\n",
        "    (u.usage_quantity * lp.pricing.default) AS actual_cost\r\n",
        "  FROM\r\n",
        "    system.billing.usage u\r\n",
        "      LEFT JOIN system.billing.list_prices lp\r\n",
        "        ON u.sku_name = lp.sku_name\r\n",
        "        AND u.cloud = lp.cloud\r\n",
        "        AND u.usage_unit = lp.usage_unit\r\n",
        "        AND (\r\n",
        "          u.usage_date BETWEEN lp.price_start_time AND lp.price_end_time\r\n",
        "          OR lp.price_end_time IS NULL\r\n",
        "        )\r\n",
        "  WHERE\r\n",
        "    1 = 1\r\n",
        "    AND u.usage_metadata.job_name LIKE '%clinical_trials%'\r\n",
        ")\r\n",
        "SELECT\r\n",
        "  ju.sku_name,\r\n",
        "  ju.usage_date,\r\n",
        "  ju.job_name,\r\n",
        "  ju.job_run_id,\r\n",
        "  ju.environment,\r\n",
        "  ju.price,\r\n",
        "  ju.currency,\r\n",
        "  SUM(ju.actual_cost) AS actual_cost,\r\n",
        "  ro.final_state AS run_status\r\n",
        "FROM\r\n",
        "  job_usage ju\r\n",
        "    LEFT JOIN run_outcomes ro ON ju.job_run_id = ro.run_id\r\n",
        "GROUP BY\r\n",
        "  ju.sku_name,\r\n",
        "  ju.usage_date,\r\n",
        "  ju.job_name,\r\n",
        "  ju.job_run_id,\r\n",
        "  ju.environment,\r\n",
        "  ju.price,\r\n",
        "  ju.currency,\r\n",
        "  ro.final_state"
      ],
      "columns": [
        {
          "displayName": "Average Cost",
          "description": "",
          "expression": "SUM(actual_cost) / COUNT(job_run_id) "
        },
        {
          "displayName": "Number of runs",
          "description": "",
          "expression": "COUNT(*)"
        },
        {
          "displayName": "Percentage Failed",
          "description": "",
          "expression": "(SUM(CASE WHEN run_status IN ('FAILED', 'TIMED_OUT', 'ERROR') THEN 1 ELSE 0 END) / COUNT(*))"
        },
        {
          "displayName": "Cost of errors",
          "description": "",
          "expression": "SUM(IF(run_status = 'ERROR', actual_cost, 0))"
        }
      ]
    },
    {
      "name": "b4ddcf17",
      "displayName": "most_expensive_job",
      "queryLines": [
        "WITH run_outcomes AS (\r\n",
        "  SELECT\r\n",
        "    run_id,\r\n",
        "    MAX_BY(result_state, period_end_time) AS final_state\r\n",
        "  FROM\r\n",
        "    system.lakeflow.job_run_timeline\r\n",
        "  WHERE\r\n",
        "    result_state IS NOT NULL\r\n",
        "  GROUP BY\r\n",
        "    run_id\r\n",
        "),\r\n",
        "job_usage AS (\r\n",
        "  SELECT\r\n",
        "    u.sku_name,\r\n",
        "    u.usage_date,\r\n",
        "    REPLACE(u.usage_metadata.job_name, '[dev frederik_toernstroem] ', '') AS job_name,\r\n",
        "    CASE WHEN u.usage_metadata.job_name LIKE '[dev%' THEN 'Dev'\r\n",
        "    ELSE 'Prod' END AS environment,\r\n",
        "    u.usage_metadata.job_run_id AS job_run_id,\r\n",
        "    lp.pricing.default AS price,\r\n",
        "    lp.currency_code AS currency,\r\n",
        "    (u.usage_quantity * lp.pricing.default) AS actual_cost\r\n",
        "  FROM\r\n",
        "    system.billing.usage u\r\n",
        "      LEFT JOIN system.billing.list_prices lp\r\n",
        "        ON u.sku_name = lp.sku_name\r\n",
        "        AND u.cloud = lp.cloud\r\n",
        "        AND u.usage_unit = lp.usage_unit\r\n",
        "        AND (\r\n",
        "          u.usage_date BETWEEN lp.price_start_time AND lp.price_end_time\r\n",
        "          OR lp.price_end_time IS NULL\r\n",
        "        )\r\n",
        "  WHERE\r\n",
        "    u.usage_metadata.job_name LIKE '%clinical_trials%'\r\n",
        "),\r\n",
        "job_run_costs AS (\r\n",
        "  SELECT\r\n",
        "    ju.job_name,\r\n",
        "    ju.environment,\r\n",
        "    SUM(ju.actual_cost) AS actual_cost\r\n",
        "  FROM\r\n",
        "    job_usage ju\r\n",
        "      LEFT JOIN run_outcomes ro ON ju.job_run_id = ro.run_id\r\n",
        "  GROUP BY\r\n",
        "    ju.job_name,\r\n",
        "    ju.environment\r\n",
        ")\r\n",
        "SELECT\r\n",
        "  job_name,\r\n",
        "  environment,\r\n",
        "  actual_cost AS total_cost\r\n",
        "FROM\r\n",
        "  job_run_costs\r\n",
        "ORDER BY\r\n",
        "  actual_cost DESC\r\n",
        "LIMIT 1"
      ]
    }
  ],
